{
  "expo": {
    "name": "Тренер Алины 4",
    "slug": "trener-aliny",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aline456.treneraliny",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Разреши доступ к микрофону, чтобы записывать еду голосом."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "a8910373-552b-46f7-8874-d97e7a67a79e"
      }
    },
    "owner": "aline456",
    "plugins": [
      "expo-audio",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Разреши доступ к камере, чтобы сфотографировать блюдо для подсчёта калорий."
        }
      ]
    ]
  }
}
